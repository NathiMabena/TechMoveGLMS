@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="page-header">
    <h2>Edit Service <span>Request</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="ServiceRequestId" />

            <div class="card mb-4">
                <div class="card-header gold">
                    <i class="fas fa-edit me-2"></i>Edit Request #@Model.ServiceRequestId
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label asp-for="ContractId" class="form-label">Contract</label>
                        <select asp-for="ContractId" class="form-control"
                                asp-items="ViewBag.Contracts">
                            <option value="">-- Select Contract --</option>
                        </select>
                        <span asp-validation-for="ContractId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Pending">Pending</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Completed">Completed</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Editable Currency Section -->
            <div class="card mb-4"
                 style="background:linear-gradient(135deg, var(--navy), var(--navy-light));
                        border:none;">
                <div class="card-header" style="background:var(--gold); color:var(--navy);">
                    <i class="fas fa-exchange-alt me-2"></i>Update Cost
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label" style="color:var(--gold)">
                                Amount in USD ($)
                            </label>
                            <input type="number" id="usdAmount" name="usdAmount"
                                   value="@Model.CostUSD"
                                   class="form-control" step="0.01" min="0"
                                   style="background:rgba(255,255,255,0.1);
                                          border-color:rgba(201,168,76,0.3);
                                          color:white;" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label" style="color:var(--gold)">
                                Exchange Rate
                            </label>
                            <input type="text" id="exchangeRate" class="form-control"
                                   readonly placeholder="Fetching..."
                                   style="background:rgba(255,255,255,0.1);
                                          border-color:rgba(201,168,76,0.3);
                                          color:var(--gold); font-weight:600;" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label" style="color:var(--gold)">
                                New Cost in ZAR (R)
                            </label>
                            <input type="text" id="zarDisplay" class="form-control"
                                   readonly
                                   value="R @Model.CostZAR.ToString("F2")"
                                   style="background:rgba(255,255,255,0.1);
                                          border-color:rgba(201,168,76,0.3);
                                          color:white; font-weight:700;" />
                        </div>
                    </div>

                    <!-- Hidden fields to submit updated costs -->
                    <input type="hidden" id="hiddenCostUSD" name="CostUSD"
                           value="@Model.CostUSD" />
                    <input type="hidden" id="hiddenCostZAR" name="CostZAR"
                           value="@Model.CostZAR" />

                    <small style="color:rgba(255,255,255,0.5)">
                        <i class="fas fa-info-circle me-1"></i>
                        Change the USD amount to recalculate at the current live rate.
                    </small>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-gold">
                    <i class="fas fa-save me-2"></i>Save Changes
                </button>
                <a asp-action="Index" class="btn btn-navy">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let currentRate = 0;

        async function fetchRate() {
            try {
                const response = await fetch('/ServiceRequest/GetRate');
                const data = await response.json();
                currentRate = data.rate;
                document.getElementById('exchangeRate').value =
                    `1 USD = R ${currentRate.toFixed(2)}`;

                // Recalculate with current value on load
                const usd = parseFloat(document.getElementById('usdAmount').value) || 0;
                const zar = usd * currentRate;
                document.getElementById('zarDisplay').value = `R ${zar.toFixed(2)}`;
                document.getElementById('hiddenCostZAR').value = zar.toFixed(2);
            } catch {
                document.getElementById('exchangeRate').value = 'Rate unavailable';
            }
        }

        document.getElementById('usdAmount').addEventListener('input', function () {
            const usd = parseFloat(this.value) || 0;
            const zar = usd * currentRate;
            document.getElementById('zarDisplay').value = `R ${zar.toFixed(2)}`;
            // Update hidden fields so form submits correct values
            document.getElementById('hiddenCostUSD').value = usd.toFixed(2);
            document.getElementById('hiddenCostZAR').value = zar.toFixed(2);
        });

        fetchRate();
    </script>
}