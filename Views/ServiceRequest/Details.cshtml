@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Request Details";
}

<div class="page-header">
    <h2>Request <span>Details</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header navy">
                <i class="fas fa-concierge-bell me-2"></i>Service Request #@Model.ServiceRequestId
            </div>
            <div class="card-body p-4">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold" style="color:var(--navy); width:35%">
                            <i class="fas fa-file-contract me-2" style="color:var(--gold)"></i>Contract
                        </td>
                        <td>@Model.Contract?.ServiceLevel</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-align-left me-2" style="color:var(--gold)"></i>Description
                        </td>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-dollar-sign me-2" style="color:var(--gold)"></i>Cost (USD)
                        </td>
                        <td>$@Model.CostUSD.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-coins me-2" style="color:var(--gold)"></i>Cost (ZAR)
                        </td>
                        <td>R @Model.CostZAR.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-info-circle me-2" style="color:var(--gold)"></i>Status
                        </td>
                        <td>
                            <span class="status-badge @(Model.Status == "Completed" ? "badge-active" :
                                                                                          Model.Status == "Pending" ? "badge-draft" : "badge-onhold")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                </table>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Index" class="btn btn-navy">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>