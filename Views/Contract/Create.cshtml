@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Create Contract";
}

<div class="page-header">
    <h2>Create <span>Contract</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header navy">
                <i class="fas fa-file-contract me-2"></i>New Contract Information
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">Client</label>
                        <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients">
                            <option value="">-- Select Client --</option>
                        </select>
                        <span asp-validation-for="ClientId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-control">
                                <option value="">-- Select Status --</option>
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                                <option value="Expired">Expired</option>
                                <option value="On Hold">On Hold</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                            <input asp-for="ServiceLevel" class="form-control"
                                   placeholder="e.g. Premium, Standard" />
                            <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Signed Agreement</label>
                        <div class="p-3 rounded" style="border: 2px dashed var(--gold); background: rgba(201,168,76,0.05)">
                            <input type="file" name="signedAgreement"
                                   class="form-control" accept=".pdf" />
                            <small class="text-muted mt-2 d-block">
                                <i class="fas fa-info-circle me-1" style="color:var(--gold)"></i>
                                Only .pdf files accepted. Max recommended size: 10MB.
                            </small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-gold">
                            <i class="fas fa-save me-2"></i>Create Contract
                        </button>
                        <a asp-action="Index" class="btn btn-navy">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}