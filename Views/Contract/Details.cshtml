@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="page-header">
    <h2>Contract <span>Details</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card mb-4">
            <div class="card-header navy">
                <i class="fas fa-file-contract me-2"></i>Contract #@Model.ContractId
            </div>
            <div class="card-body p-4">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold" style="color:var(--navy); width:35%">
                            <i class="fas fa-user me-2" style="color:var(--gold)"></i>Client
                        </td>
                        <td>@Model.Client?.Name</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-calendar me-2" style="color:var(--gold)"></i>Start Date
                        </td>
                        <td>@Model.StartDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-calendar-times me-2" style="color:var(--gold)"></i>End Date
                        </td>
                        <td>@Model.EndDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-info-circle me-2" style="color:var(--gold)"></i>Status
                        </td>
                        <td>
                            <span class="status-badge @(Model.Status == "Active" ? "badge-active" :
                                                                                          Model.Status == "Expired" ? "badge-expired" :
                                                                                          Model.Status == "On Hold" ? "badge-onhold" : "badge-draft")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-layer-group me-2" style="color:var(--gold)"></i>Service Level
                        </td>
                        <td>@Model.ServiceLevel</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-file-pdf me-2" style="color:var(--gold)"></i>Agreement
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                            {
                                <a asp-action="Download" asp-route-filePath="@Model.SignedAgreementPath"
                                   class="btn btn-sm btn-gold">
                                    <i class="fas fa-download me-1"></i>Download PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No file uploaded</span>
                            }
                        </td>
                    </tr>
                </table>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-gold">
                        <i class="fas fa-edit me-2"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-navy">Back to List</a>
                </div>
            </div>
        </div>
    </div>

    @if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
    {
        <div class="col-md-5">
            <div class="card">
                <div class="card-header gold">
                    <i class="fas fa-concierge-bell me-2"></i>Service Requests (@Model.ServiceRequests.Count())
                </div>
                <div class="card-body p-3">
                    @foreach (var sr in Model.ServiceRequests)
                    {
                        <div class="p-2 mb-2 rounded" style="background:var(--light-bg)">
                            <small class="fw-bold" style="color:var(--navy)">@sr.Description</small><br />
                            <small class="text-muted">R @sr.CostZAR.ToString("F2")</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>