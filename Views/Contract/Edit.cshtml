@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
}

<div class="page-header">
    <h2>Edit <span>Contract</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header gold">
                <i class="fas fa-file-contract me-2"></i>Edit Contract Details
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="ContractId" />
                    <input type="hidden" asp-for="SignedAgreementPath" />

                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">Client</label>
                        <select asp-for="ClientId" class="form-control"
                                asp-items="ViewBag.Clients">
                            <option value="">-- Select Client --</option>
                        </select>
                        <span asp-validation-for="ClientId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Draft">Draft</option>
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="On Hold">On Hold</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                        <input asp-for="ServiceLevel" class="form-control" />
                        <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Signed Agreement (PDF)</label>
                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <div class="p-2 mb-2 rounded d-flex align-items-center gap-2"
                                 style="background:rgba(201,168,76,0.1);
                                            border:1px solid rgba(201,168,76,0.3)">
                                <i class="fas fa-file-pdf" style="color:var(--gold)"></i>
                                <span class="small text-muted">Current file uploaded</span>
                                <a asp-controller="Contract" asp-action="Download"
                                   asp-route-filePath="@Model.SignedAgreementPath"
                                   class="btn btn-sm btn-gold ms-auto">
                                    <i class="fas fa-download me-1"></i>Download
                                </a>
                            </div>
                        }
                        <div class="p-3 rounded"
                             style="border: 2px dashed var(--gold);
                                    background: rgba(201,168,76,0.05)">
                            <input type="file" name="signedAgreement"
                                   class="form-control" accept=".pdf" />
                            <small class="text-muted mt-2 d-block">
                                <i class="fas fa-info-circle me-1" style="color:var(--gold)"></i>
                                Upload a new PDF to replace the existing one. Leave empty to keep current.
                            </small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-gold">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-navy">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}