@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<div class="page-header">
    <h2>Delete <span>Contract</span></h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header" style="background:#dc3545; color:white;">
                <i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion
            </div>
            <div class="card-body p-4">

                <table class="table table-borderless mb-3">
                    <tr>
                        <td class="fw-bold" style="color:var(--navy); width:35%">
                            <i class="fas fa-user me-2" style="color:var(--gold)"></i>Client
                        </td>
                        <td>@Model.Client?.Name</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-layer-group me-2" style="color:var(--gold)"></i>Service Level
                        </td>
                        <td>@Model.ServiceLevel</td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-info-circle me-2" style="color:var(--gold)"></i>Status
                        </td>
                        <td>
                            <span class="status-badge @(Model.Status == "Active" ? "badge-active" :
                                                                                          Model.Status == "Expired" ? "badge-expired" :
                                                                                          Model.Status == "On Hold" ? "badge-onhold" : "badge-draft")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold" style="color:var(--navy)">
                            <i class="fas fa-calendar-times me-2" style="color:var(--gold)"></i>End Date
                        </td>
                        <td>@Model.EndDate.ToString("dd MMM yyyy")</td>
                    </tr>
                </table>

                <div class="p-3 rounded mb-3"
                     style="background:rgba(220,53,69,0.08);
                            border: 1px solid rgba(220,53,69,0.3)">
                    <p class="fw-bold mb-1" style="color:#dc3545">
                        <i class="fas fa-exclamation-circle me-2"></i>Warning
                    </p>
                    <p class="mb-0 small text-muted">
                        Deleting this contract will also delete all
                        <strong>service requests</strong> linked to it.
                        This action <strong>cannot be undone.</strong>
                    </p>
                </div>

                <form asp-action="Delete" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Yes, Delete
                    </button>
                    <a asp-action="Index" class="btn btn-navy">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>