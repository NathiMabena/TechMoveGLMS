@model IEnumerable<TechMoveGLMS.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
}

<div class="page-header">
    <h2>Contract <span>Management</span></h2>
    <a asp-action="Create" class="btn btn-gold">
        <i class="fas fa-plus me-2"></i>New Contract
    </a>
</div>

<!-- Airbnb Style Search Bar -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="airbnb-search">
        <div class="search-segment">
            <label>Status</label>
            <select name="status" class="search-input">
                <option value="">All Statuses</option>
                <option value="Draft" selected="@(ViewBag.SelectedStatus == "Draft")">Draft</option>
                <option value="Active" selected="@(ViewBag.SelectedStatus == "Active")">Active</option>
                <option value="Expired" selected="@(ViewBag.SelectedStatus == "Expired")">Expired</option>
                <option value="On Hold" selected="@(ViewBag.SelectedStatus == "On Hold")">On Hold</option>
            </select>
        </div>

        <div class="search-divider"></div>

        <div class="search-segment">
            <label>Start Date From</label>
            <input type="date" name="startDate" class="search-input"
                   value="@ViewBag.StartDate" placeholder="Add start date" />
        </div>

        <div class="search-divider"></div>

        <div class="search-segment">
            <label>End Date To</label>
            <input type="date" name="endDate" class="search-input"
                   value="@ViewBag.EndDate" placeholder="Add end date" />
        </div>

        <button type="submit" class="search-btn">
            <i class="fas fa-search"></i>
        </button>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.SelectedStatus as string) ||
        !string.IsNullOrEmpty(ViewBag.StartDate as string) ||
        !string.IsNullOrEmpty(ViewBag.EndDate as string))
    {
        <div class="text-center mt-2">
            <a asp-action="Index" class="text-muted small">
                <i class="fas fa-times me-1"></i>Clear filters
            </a>
        </div>
    }
</form>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-file-contract fa-3x mb-3" style="color:var(--gold)"></i>
            <h5 style="color:var(--navy)">No Contracts Found</h5>
            <p class="text-muted">Try adjusting your filters or create a new contract.</p>
            <a asp-action="Create" class="btn btn-gold">New Contract</a>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-header navy d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-file-contract me-2"></i>@item.ServiceLevel</span>
                        <span class="status-badge @(item.Status == "Active" ? "badge-active" :
                                                                                  item.Status == "Expired" ? "badge-expired" :
                                                                                  item.Status == "On Hold" ? "badge-onhold" : "badge-draft")">
                    @item.Status
                </span>
            </div>
            <div class="card-body">
                <p class="mb-2">
                    <i class="fas fa-user me-2" style="color:var(--gold)"></i>
                    <strong>@item.Client?.Name</strong>
                </p>
                <p class="mb-2">
                    <i class="fas fa-calendar me-2" style="color:var(--gold)"></i>
                    @item.StartDate.ToString("dd MMM yyyy")
                </p>
                <p class="mb-2">
                    <i class="fas fa-calendar-times me-2" style="color:var(--gold)"></i>
                    @item.EndDate.ToString("dd MMM yyyy")
                </p>
                @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                        {
                            <p class="mb-0">
                                <i class="fas fa-file-pdf me-2" style="color:var(--gold)"></i>
                                <a asp-action="Download" asp-route-filePath="@item.SignedAgreementPath"
                                   style="color:var(--gold)">Download PDF</a>
                            </p>
                        }
                    </div>
                    <div class="card-footer bg-white d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.ContractId"
                           class="btn btn-sm btn-navy">
                            <i class="fas fa-eye me-1"></i>Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.ContractId"
                           class="btn btn-sm btn-gold">
                            <i class="fas fa-edit me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ContractId"
                           class="btn btn-sm btn-danger">
                            <i class="fas fa-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}