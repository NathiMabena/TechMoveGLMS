@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2>Welcome to <span>TechMove</span> GLMS</h2>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card navy">
            <p>Total Clients</p>
            <h2><i class="fas fa-users me-2"></i>@ViewBag.TotalClients</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card gold">
            <p>Active Contracts</p>
            <h2><i class="fas fa-file-contract me-2"></i>@ViewBag.ActiveContracts</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card navy">
            <p>Service Requests</p>
            <h2><i class="fas fa-concierge-bell me-2"></i>@ViewBag.TotalRequests</h2>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header navy">
                <i class="fas fa-users me-2"></i>Client Management
            </div>
            <div class="card-body">
                <p class="text-muted">Manage all TechMove clients, contact details and regions.</p>
                <a asp-controller="Client" asp-action="Index" class="btn btn-navy">
                    View Clients
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header gold">
                <i class="fas fa-file-contract me-2"></i>Contract Management
            </div>
            <div class="card-body">
                <p class="text-muted">Create and manage contracts, upload signed agreements.</p>
                <a asp-controller="Contract" asp-action="Index" class="btn btn-gold">
                    View Contracts
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header navy">
                <i class="fas fa-concierge-bell me-2"></i>Service Requests
            </div>
            <div class="card-body">
                <p class="text-muted">Raise and track service requests with live currency conversion.</p>
                <a asp-controller="ServiceRequest" asp-action="Index" class="btn btn-navy">
                    View Requests
                </a>
            </div>
        </div>
    </div>
</div>