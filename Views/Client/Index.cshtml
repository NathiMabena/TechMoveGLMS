@model IEnumerable<TechMoveGLMS.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="page-header">
    <h2>Client <span>Management</span></h2>
    <a asp-action="Create" class="btn btn-gold">
        <i class="fas fa-plus me-2"></i>Add Client
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-users fa-3x mb-3" style="color:var(--gold)"></i>
            <h5 style="color:var(--navy)">No Clients Yet</h5>
            <p class="text-muted">Get started by adding your first client.</p>
            <a asp-action="Create" class="btn btn-gold">Add Client</a>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-header navy">
                        <i class="fas fa-user me-2"></i>@item.Name
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <i class="fas fa-envelope me-2" style="color:var(--gold)"></i>
                            @item.ContactDetails
                        </p>
                        <p class="mb-0">
                            <i class="fas fa-globe me-2" style="color:var(--gold)"></i>
                            @item.Region
                        </p>
                    </div>
                    <div class="card-footer bg-white d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.ClientId"
                           class="btn btn-sm btn-navy">
                            <i class="fas fa-eye me-1"></i>Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.ClientId"
                           class="btn btn-sm btn-gold">
                            <i class="fas fa-edit me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ClientId"
                           class="btn btn-sm btn-danger">
                            <i class="fas fa-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}