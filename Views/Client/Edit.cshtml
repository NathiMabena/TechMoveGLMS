@model TechMoveGLMS.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="page-header">
    <h2>Edit <span>Client</span></h2>
    <a asp-action="Index" class="btn btn-navy">
        <i class="fas fa-arrow-left me-2"></i>Back to Clients
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header gold">
                <i class="fas fa-user-edit me-2"></i>Edit Client Information
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="ClientId" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Client Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactDetails" class="form-label">Contact Details</label>
                        <input asp-for="ContactDetails" class="form-control" />
                        <span asp-validation-for="ContactDetails" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Region" class="form-label">Region</label>
                        <input asp-for="Region" class="form-control" />
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-gold">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-navy">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}